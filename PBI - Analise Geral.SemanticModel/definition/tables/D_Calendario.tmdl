	partition D_Calendario = calculated
		mode: import
		source = ```
				
				
				    VAR DataInicio = IF(MIN(F_Pedidos[shipped_date])< MIN(F_Pedidos[order_date]), MIN(F_Pedidos[shipped_date]), IF(MIN(F_Pedidos[order_date]) < MIN(F_Pedidos[required_date]), MIN(F_Pedidos[order_date]), MIN(F_Pedidos[required_date])))
				    VAR DataFim = IF(MAX(F_Pedidos[shipped_date])>= MAX(F_Pedidos[order_date]), MAX(F_Pedidos[shipped_date]), IF(MAX(F_Pedidos[order_date])>= MAX(F_Pedidos[required_date]), MAX(F_Pedidos[order_date]), MAX(F_Pedidos[required_date])))
				
				RETURN
				
				ADDCOLUMNS(
				    CALENDAR(DataInicio, DataFim),
				    "Ano", YEAR([Date]),
				    "Mes_Nome", FORMAT([Date], "MMMM"),
				    "Mes_Numero", MONTH([Date]),
				    "Mes_ano", FORMAT([Date], "mm-yyyy"),
				    "Serial_mes_ano", FORMAT([Date], "yyyymm"))
				```

	annotation PBI_Id = cfee70b2923b40b9999fd9cb36bac3ff

